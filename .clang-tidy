# concurrency-mt-unsafe is disabled: mua is single-threaded by design (no
# threads exist anywhere), so getenv-class findings are pure noise. Re-enable
# if a thread is ever introduced.
Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  cert-*,
  clang-analyzer-*,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  concurrency-*,
  -concurrency-mt-unsafe,
  misc-*,
  -misc-include-cleaner,
  -misc-unused-parameters,
  performance-*,
  portability-*,
  readability-function-size,
  readability-braces-around-statements,
  readability-misleading-indentation,
  readability-duplicate-include
WarningsAsErrors: '*'
HeaderFilterRegex: 'src/mua/'
FormatStyle: file
CheckOptions:
  readability-function-size.LineThreshold: 80
